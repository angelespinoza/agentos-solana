# ══════════════════════════════════════════════════════
# AgentOS — Variables de Entorno
# ══════════════════════════════════════════════════════

# ── Red Solana ────────────────────────────────────────
# "devnet" para pruebas | "mainnet-beta" para producción
NEXT_PUBLIC_SOLANA_NETWORK=devnet

# RPC de mainnet (Helius es más estable que el público)
# Obtener en: https://helius.dev (plan gratis disponible)
MAINNET_RPC_URL=https://mainnet.helius-rpc.com/?api-key=TU_HELIUS_KEY

# ── Program ID ────────────────────────────────────────
# Se obtiene tras ejecutar: ./scripts/deploy-mainnet.sh
NEXT_PUBLIC_PROGRAM_ID=REEMPLAZAR_CON_PROGRAM_ID_TRAS_DEPLOY

# ── Supabase ──────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJxxx

# ── LLM Providers ────────────────────────────────────
# Keys de plataforma (fallback cuando el usuario no trae la suya)
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx
GROQ_API_KEY=gsk_xxx
TOGETHER_API_KEY=xxx

# ── Encriptación de API Keys de usuarios ──────────────
# ⚠️ NUNCA cambiar en producción — hace inaccesibles las keys guardadas
ENCRYPTION_SECRET=string_aleatorio_minimo_64_caracteres_generado_con_openssl_rand

# ── Platform fee & wallet ─────────────────────────────
# Wallet que recibe el escrow de todos los pagos x402
PLATFORM_WALLET=TU_PUBKEY_DE_MAINNET
# Keypair en base58 para que el worker firme los payouts al owner
# ⚠️ Mantener en secreto y con SOL para fees de transacción
PLATFORM_KEYPAIR_BS58=TU_KEYPAIR_BASE58
# Comisión en basis points: 500 = 5%
PLATFORM_FEE_BPS=500
# USDC mainnet oficial
USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# ── x402 ──────────────────────────────────────────────
X402_FACILITATOR_URL=https://x402.org/facilitator
CDP_API_KEY_NAME=xxx
CDP_API_KEY_PRIVATE=xxx

# ── Admin ─────────────────────────────────────────────
ADMIN_SECRET=string_seguro_para_el_endpoint_admin

# ── App ───────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://agentos.xyz

# ── Helius (NFT verification) ─────────────────────────
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=TU_HELIUS_KEY
